#property strict
#include <Trade\Trade.mqh>

input int      Magic          = 77777;   
input double   LotSize        = 1;
input double   DistancePoints = 2;       
input double   TakeProfit     = 100;     
input double    StopLoss      = 3;       
input double  TriggerTrail   = 0.50;       

input int ADXPeriod = 14;
input int ADXThreshold = 25;
input ENUM_TIMEFRAMES TF  = PERIOD_M5;
int adxHandle;

//--- SESSION INPUTS (Based on standard Broker Server Time)
input int      StartHour      = 13;      // NY Start (13:00 Server Time)
input int      EndHour        = 22;      // NY End (22:00 Server Time)

CTrade         trade;
datetime       lastMinute;

int OnInit()
{
   trade.SetExpertMagicNumber(Magic);
  // EventSetTimer(1); // Set to 1 second for higher precision
   EventSetMillisecondTimer(500);
   adxHandle = iADX(_Symbol, TF, ADXPeriod);
   return(INIT_SUCCEEDED);
}

void OnDeinit(const int reason)
{
   EventKillTimer();
}
